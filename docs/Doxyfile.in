PROJECT_NAME           = DSpecM1D
PROJECT_NUMBER         = @PROJECT_VERSION@
OUTPUT_DIRECTORY       = @DSPECM1D_DOCS_OUTPUT_DIR@
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
HAVE_DOT               = @DSPECM1D_DOXYGEN_HAVE_DOT@
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
STRIP_FROM_PATH        = @CMAKE_SOURCE_DIR@
USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/README.md
INPUT                  = @CMAKE_SOURCE_DIR@/README.md \
                         @CMAKE_SOURCE_DIR@/DSpecM1D \
                         @CMAKE_SOURCE_DIR@/tutorials/t1.cpp
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
