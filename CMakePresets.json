{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "description": "Default development preset with tests, tutorials, benchmarks, and smoke checks.",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "DSPECM1D_BUILD_TESTS": "ON",
        "DSPECM1D_BUILD_BENCHMARKS": "ON",
        "DSPECM1D_BUILD_TUTORIALS": "ON",
        "DSPECM1D_BUILD_TOOLS": "ON",
        "DSPECM1D_ENABLE_SMOKE_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release preset for benchmarking and exercise validation.",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DSPECM1D_BUILD_TESTS": "ON",
        "DSPECM1D_BUILD_BENCHMARKS": "ON",
        "DSPECM1D_BUILD_TUTORIALS": "ON",
        "DSPECM1D_BUILD_TOOLS": "ON",
        "DSPECM1D_ENABLE_SMOKE_TESTS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug preset with tests, tutorials, benchmarks, and smoke checks enabled.",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DSPECM1D_BUILD_TESTS": "ON",
        "DSPECM1D_BUILD_BENCHMARKS": "ON",
        "DSPECM1D_BUILD_TUTORIALS": "ON",
        "DSPECM1D_BUILD_TOOLS": "ON",
        "DSPECM1D_ENABLE_SMOKE_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "displayName": "Build Development",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "release"
    },
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "debug"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "displayName": "Test Development",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "displayName": "Test Release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "displayName": "Test Debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
