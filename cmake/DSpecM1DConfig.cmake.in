@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

find_dependency(PkgConfig)
find_dependency(FFTW REQUIRED)
find_dependency(OpenMP REQUIRED)

include(FetchContent)

set(FETCHCONTENT_BASE_DIR "${CMAKE_BINARY_DIR}/_deps" CACHE PATH
    "FetchContent dependency cache for this build tree" FORCE)
set(FETCHCONTENT_UPDATES_DISCONNECTED ON CACHE BOOL "Disable FetchContent updates")

FetchContent_Declare(
  Eigen3
  GIT_REPOSITORY https://gitlab.com/libeigen/eigen.git
  GIT_TAG 3.4.0
  GIT_SHALLOW TRUE
  FIND_PACKAGE_ARGS NAMES Eigen3
)
FetchContent_Declare(
  FFTWpp
  GIT_REPOSITORY https://github.com/da380/FFTWpp.git
  GIT_TAG 06cc1fb04c4398407839e637cb5414b179b0e9c3
  GIT_SHALLOW TRUE
)
FetchContent_Declare(
  GaussQuad
  GIT_REPOSITORY https://github.com/da380/GaussQuad.git
  GIT_TAG fbe37c7eef93695317dbf9c48715110bf64c800f
  GIT_SHALLOW TRUE
)
FetchContent_Declare(
  GSHTRANS
  GIT_REPOSITORY https://github.com/da380/GSHTrans.git
  GIT_TAG b880ac9aeacdb54a6480fca3aee70a20a727c678
  GIT_SHALLOW TRUE
)
FetchContent_Declare(
  Interpolation
  GIT_REPOSITORY https://github.com/da380/Interpolation.git
  GIT_TAG 1557aad571ceac1899c2d3795696aa4047f41d8a
  GIT_SHALLOW TRUE
)
function(dspecm1d_fetchcontent_make_available_noinstall)
  set(_dspecm1d_saved_skip_install_rules ${CMAKE_SKIP_INSTALL_RULES})
  set(CMAKE_SKIP_INSTALL_RULES ON)
  FetchContent_MakeAvailable(${ARGV})
  set(CMAKE_SKIP_INSTALL_RULES ${_dspecm1d_saved_skip_install_rules} PARENT_SCOPE)
endfunction()

dspecm1d_fetchcontent_make_available_noinstall(
  Eigen3
  GaussQuad
  GSHTRANS
  Interpolation
)

set_and_check(DSPECM1D_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")

if(NOT TARGET DSpecM1D::DSpecM1D)
  add_library(DSpecM1D::DSpecM1D INTERFACE IMPORTED)
  set_target_properties(DSpecM1D::DSpecM1D PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${DSPECM1D_INCLUDE_DIR}"
    INTERFACE_LINK_LIBRARIES "Eigen3::Eigen;GaussQuad;Interpolation;GSHTrans;OpenMP::OpenMP_CXX"
  )
endif()
